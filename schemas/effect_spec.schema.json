{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "EffectSpec",
  "type": "object",
  "required": [
    "id",
    "action",
    "preconditions",
    "causes",
    "risk",
    "reversibility"
  ],
  "properties": {
    "id": {
      "type": "string"
    },
    "action": {
      "type": "string"
    },
    "preconditions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "causes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "may_cause": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "exceptions": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "invariants": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "risk": {
      "type": "string",
      "enum": [
        "low",
        "medium",
        "high",
        "critical"
      ]
    },
    "reversibility": {
      "type": "string",
      "enum": [
        "reversible",
        "compensable",
        "irreversible",
        "unknown"
      ]
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "evidence": {
      "type": "object"
    },
    "scope": {
      "type": "object"
    }
  }
}
