{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "EffectSpec",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "action",
    "preconditions",
    "causes",
    "risk",
    "reversibility"
  ],
  "properties": {
    "id": {
      "$ref": "#/$defs/id"
    },
    "action": {
      "$ref": "#/$defs/id"
    },
    "preconditions": {
      "$ref": "#/$defs/predicate_list"
    },
    "causes": {
      "$ref": "#/$defs/predicate_list"
    },
    "may_cause": {
      "$ref": "#/$defs/predicate_list"
    },
    "exceptions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "when",
          "effect"
        ],
        "properties": {
          "when": {
            "type": "string",
            "minLength": 1
          },
          "effect": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "invariants": {
      "$ref": "#/$defs/predicate_list"
    },
    "risk": {
      "$ref": "#/$defs/risk"
    },
    "reversibility": {
      "type": "string",
      "enum": [
        "reversible",
        "compensable",
        "irreversible",
        "unknown"
      ]
    },
    "evidence": {
      "$ref": "#/$defs/evidence"
    },
    "scope": {
      "$ref": "#/$defs/scope"
    }
  },
  "$defs": {
    "id": {
      "type": "string",
      "pattern": "^[A-Za-z][A-Za-z0-9_.:-]*$"
    },
    "predicate_list": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "risk": {
      "type": "string",
      "enum": [
        "low",
        "medium",
        "high",
        "critical"
      ]
    },
    "evidence": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "source_traces": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/id"
          }
        },
        "counterexamples": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/id"
          }
        },
        "support_count": {
          "type": "integer",
          "minimum": 0
        },
        "counterexample_count": {
          "type": "integer",
          "minimum": 0
        },
        "confidence_model": {
          "type": "string",
          "enum": [
            "uncalibrated",
            "beta_posterior",
            "calibrated_eval"
          ]
        },
        "confidence_label": {
          "type": "string",
          "enum": [
            "low",
            "medium",
            "high"
          ]
        }
      }
    },
    "scope": {
      "type": "object",
      "additionalProperties": true
    }
  }
}
