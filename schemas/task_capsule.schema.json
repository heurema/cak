{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "TaskCapsule",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "goal",
    "constraints",
    "budget",
    "verifier_plan"
  ],
  "properties": {
    "id": {
      "$ref": "#/$defs/id"
    },
    "goal": {
      "type": "string",
      "minLength": 1
    },
    "env_ref": {
      "$ref": "#/$defs/id"
    },
    "constraints": {
      "$ref": "#/$defs/string_list"
    },
    "input_artifacts": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/id"
      }
    },
    "output_schema": {
      "$ref": "#/$defs/id"
    },
    "budget": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "max_usd": {
          "type": "number",
          "minimum": 0
        },
        "max_tokens": {
          "type": "integer",
          "minimum": 0
        },
        "max_tool_calls": {
          "type": "integer",
          "minimum": 0
        },
        "max_frontier_calls": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "provider_policy": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "preferred_profile": {
          "$ref": "#/$defs/id"
        },
        "allow_frontier_escalation": {
          "type": "boolean"
        }
      }
    },
    "verifier_plan": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/id"
      }
    }
  },
  "$defs": {
    "id": {
      "type": "string",
      "pattern": "^[A-Za-z][A-Za-z0-9_.:-]*$"
    },
    "string_list": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}
