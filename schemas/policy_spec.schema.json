{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "PolicySpec",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "name",
    "enforcement"
  ],
  "properties": {
    "id": {
      "$ref": "#/$defs/id"
    },
    "name": {
      "$ref": "#/$defs/id"
    },
    "when": {
      "$ref": "#/$defs/predicate_list"
    },
    "expr": {
      "type": "string",
      "minLength": 1
    },
    "requires": {
      "$ref": "#/$defs/predicate_list"
    },
    "actions": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "enforcement": {
      "type": "string",
      "enum": [
        "allow",
        "warn",
        "block",
        "require_approval",
        "sandbox_only",
        "quarantine"
      ]
    },
    "proof_level": {
      "type": "string",
      "enum": [
        "L0",
        "L1",
        "L2",
        "L3",
        "L4",
        "L5"
      ]
    }
  },
  "$defs": {
    "id": {
      "type": "string",
      "pattern": "^[A-Za-z][A-Za-z0-9_.:-]*$"
    },
    "predicate_list": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}
