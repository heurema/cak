{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SkillSpec",
  "type": "object",
  "required": [
    "id",
    "name",
    "version",
    "trigger",
    "preconditions",
    "steps",
    "postconditions",
    "risk",
    "status"
  ],
  "properties": {
    "id": {
      "type": "string"
    },
    "name": {
      "type": "string"
    },
    "version": {
      "type": "string"
    },
    "kind": {
      "type": "string",
      "enum": [
        "option",
        "intervention",
        "workflow",
        "executable_program"
      ]
    },
    "trigger": {
      "type": "object"
    },
    "failure_signature": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "preconditions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "steps": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "postconditions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "tests": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "rollback": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "risk": {
      "type": "string",
      "enum": [
        "low",
        "medium",
        "high",
        "critical"
      ]
    },
    "evidence": {
      "type": "object"
    },
    "scope": {
      "type": "object"
    },
    "status": {
      "type": "string",
      "enum": [
        "draft",
        "candidate",
        "shadow_tested",
        "verified",
        "approved",
        "active",
        "deprecated",
        "quarantined",
        "archived"
      ]
    }
  }
}
