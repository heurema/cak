{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SkillSpec",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "name",
    "version",
    "trigger",
    "preconditions",
    "steps",
    "postconditions",
    "risk",
    "status"
  ],
  "properties": {
    "id": {
      "$ref": "#/$defs/id"
    },
    "name": {
      "$ref": "#/$defs/id"
    },
    "version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "kind": {
      "type": "string",
      "enum": [
        "option",
        "intervention",
        "workflow",
        "executable_program"
      ]
    },
    "trigger": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "goal_matches": {
          "$ref": "#/$defs/id"
        }
      }
    },
    "failure_signature": {
      "$ref": "#/$defs/predicate_list"
    },
    "preconditions": {
      "$ref": "#/$defs/predicate_list"
    },
    "steps": {
      "$ref": "#/$defs/predicate_list"
    },
    "postconditions": {
      "$ref": "#/$defs/predicate_list"
    },
    "tests": {
      "$ref": "#/$defs/predicate_list"
    },
    "rollback": {
      "$ref": "#/$defs/predicate_list"
    },
    "risk": {
      "$ref": "#/$defs/risk"
    },
    "evidence": {
      "$ref": "#/$defs/evidence"
    },
    "scope": {
      "$ref": "#/$defs/scope"
    },
    "status": {
      "type": "string",
      "enum": [
        "draft",
        "candidate",
        "shadow_tested",
        "verified",
        "approved",
        "active",
        "deprecated",
        "quarantined",
        "archived"
      ]
    }
  },
  "$defs": {
    "id": {
      "type": "string",
      "pattern": "^[A-Za-z][A-Za-z0-9_.:-]*$"
    },
    "predicate_list": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "risk": {
      "type": "string",
      "enum": [
        "low",
        "medium",
        "high",
        "critical"
      ]
    },
    "evidence": {
      "type": "object",
      "additionalProperties": true
    },
    "scope": {
      "type": "object",
      "additionalProperties": true
    }
  }
}
