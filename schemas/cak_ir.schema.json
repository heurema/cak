{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://heurema.org/schemas/cak/cak_ir.schema.json",
  "title": "CAK IR Artifact",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "cak_ir_version",
    "kind",
    "id",
    "metadata"
  ],
  "properties": {
    "cak_ir_version": {
      "type": "string",
      "pattern": "^0\\.[0-9]+\\.[0-9]+$"
    },
    "kind": {
      "type": "string",
      "enum": [
        "GoalSpec",
        "EnvSpec",
        "ActionSpec",
        "EffectSpec",
        "SkillSpec",
        "ContractSpec",
        "MemoryRecord",
        "PolicySpec",
        "TransactionSpec",
        "EvidenceSpec",
        "ScopeSpec",
        "VerifierPlan",
        "ReplaySpec",
        "EvalSpec",
        "ProviderProfile",
        "TaskCapsule",
        "IncidentReport"
      ]
    },
    "id": {
      "$ref": "#/$defs/id"
    },
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "created_at",
        "status"
      ],
      "properties": {
        "created_at": {
          "type": "string",
          "format": "date-time"
        },
        "status": {
          "type": "string",
          "enum": [
            "draft",
            "candidate",
            "shadow_tested",
            "verified",
            "approved",
            "active",
            "deprecated",
            "quarantined",
            "archived"
          ]
        },
        "owner": {
          "$ref": "#/$defs/id"
        },
        "version": {
          "type": "string",
          "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
        }
      }
    },
    "scope": {
      "$ref": "#/$defs/scope"
    },
    "evidence": {
      "$ref": "#/$defs/evidence"
    }
  },
  "$defs": {
    "id": {
      "type": "string",
      "pattern": "^[A-Za-z][A-Za-z0-9_.:-]*$"
    },
    "scope": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "env": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/id"
          }
        },
        "tenant": {
          "$ref": "#/$defs/id"
        },
        "role": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/id"
          }
        },
        "data_class": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/id"
          }
        },
        "valid_until": {
          "type": "string",
          "format": "date-time"
        },
        "expires_on": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "evidence": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "source_traces": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/id"
          }
        },
        "counterexamples": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/id"
          }
        },
        "support_count": {
          "type": "integer",
          "minimum": 0
        },
        "counterexample_count": {
          "type": "integer",
          "minimum": 0
        },
        "confidence_model": {
          "type": "string",
          "enum": [
            "uncalibrated",
            "beta_posterior",
            "calibrated_eval"
          ]
        },
        "confidence_label": {
          "type": "string",
          "enum": [
            "low",
            "medium",
            "high"
          ]
        },
        "verifier_reports": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/id"
          }
        }
      }
    }
  }
}
